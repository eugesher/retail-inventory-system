# IAM admin endpoints (apps/api-gateway/src/modules/iam)
#
# Five endpoints for managing the relational RBAC schema at runtime:
#   1. GET    /api/iam/roles                       — list roles
#   2. POST   /api/iam/roles                       — create role
#   3. PATCH  /api/iam/roles/:id                   — patch description / replace permissions
#   4. POST   /api/iam/staff/:id/roles             — assign roles to a staff user
#   5. DELETE /api/iam/staff/:id/roles/:roleName   — revoke a role from a staff user
#
# All endpoints sit behind a bearer token and a `@RequiresPermission(...)` gate:
#   • iam:role-edit gates the role-management endpoints (#1, #2, #3)
#   • iam:assign    gates the staff-role assignment endpoints (#4, #5)
#
# The seeded admin (admin@example.com) holds every code in the registry —
# log in via /api/auth/login first, copy `accessToken`, then paste it
# into the {{adminToken}} variable below.

@baseUrl = {{ENV_BASE_URL}}
@adminToken = REPLACE_ME

###

# @name listRoles
# Returns Role[] sorted by `name` ASC. 200 on success.
GET {{baseUrl}}/iam/roles
Authorization: Bearer {{adminToken}}

###

# @name createRole
# Body shape (CreateRoleRequestDto):
#   name: ^[a-z][a-z0-9-]*$, 1..64 — unique in role.name (409 on duplicate)
#   description?: string, ≤255
#   permissionCodes: PermissionCodeEnum[] — every code must exist (400 lists missing)
# Returns 201 with the persisted Role projection.
POST {{baseUrl}}/iam/roles
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "audit-reader",
  "description": "Read-only auditor",
  "permissionCodes": ["audit:read"]
}

###

# @name updateRole
# Body shape (UpdateRoleRequestDto): description? | permissionCodes?
# Both omitted → 400 "No-op patch". permissionCodes is a REPLACE (not merge);
# unknown codes → 400 with the missing list. Returns 200 with the updated Role.
PATCH {{baseUrl}}/iam/roles/REPLACE_WITH_ROLE_ID
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "description": "Audit log read-only access",
  "permissionCodes": ["audit:read", "order:read"]
}

###

# @name assignStaffRoles
# Body shape (AssignStaffRoleRequestDto): { roleNames: string[] } (non-empty, unique)
# Idempotent — re-assigning a role the user already has is a no-op (200 either way).
# Unknown role name → 400. Missing/suspended staff user → 404.
# Returns 200 with the updated StaffUser projection { id, email, roleNames }.
POST {{baseUrl}}/iam/staff/REPLACE_WITH_STAFF_USER_ID/roles
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "roleNames": ["audit-reader"]
}

###

# @name revokeStaffRole
# Path params: id (staff user uuid), roleName (e.g. "audit-reader").
# Returns 204 on success. 404 "Role not bound" if the user doesn't have that
# role. 409 "Cannot revoke the last remaining role" if it would empty the user.
DELETE {{baseUrl}}/iam/staff/REPLACE_WITH_STAFF_USER_ID/roles/audit-reader
Authorization: Bearer {{adminToken}}
