{
  "name": "retail-inventory-system",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "nest build --all",
    "build:api-gateway": "nest build api-gateway",
    "build:inventory-service": "nest build inventory-service",
    "build:order-service": "nest build order-service",
    "build:notification-service": "nest build notification-service",
    "start:dev": "concurrently --names \"API_GATEWAY,INVENTORY_SERVICE,ORDER_SERVICE,NOTIFICATION_SERVICE\" --prefix \"[{name}]\" --prefix-colors \"magenta,blue,cyan,yellow\" \"yarn start:dev:api-gateway\" \"yarn start:dev:inventory-service\" \"yarn start:dev:order-service\" \"yarn start:dev:notification-service\"",
    "start:dev:api-gateway": "nest start api-gateway --watch",
    "start:dev:inventory-service": "nest start inventory-service --watch",
    "start:dev:order-service": "nest start order-service --watch",
    "start:dev:notification-service": "nest start notification-service --watch",
    "start:prod:api-gateway": "node dist/apps/api-gateway/main.js",
    "start:prod:inventory-service": "node dist/apps/inventory-service/main.js",
    "start:prod:order-service": "node dist/apps/order-service/main.js",
    "start:prod:notification-service": "node dist/apps/notification-service/main.js",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "format:check": "prettier --check \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "prepare": "husky",
    "typeorm:migration-cli": "ts-node --project tsconfig.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d /migrations/config/data-source.ts",
    "migration:create": "ts-node ./scripts/migration-create.ts",
    "migration:run": "yarn typeorm:migration-cli migration:run",
    "migration:revert": "yarn typeorm:migration-cli migration:revert",
    "migration:show": "yarn typeorm:migration-cli migration:show"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.13",
    "@nestjs/microservices": "^11.1.13",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/typeorm": "^11.0.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "joi": "^18.0.2",
    "mysql2": "^3.17.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typeorm": "^0.3.28",
    "webpack": "^5.105.2",
    "webpack-node-externals": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@nestjs/cli": "^11.0.16",
    "@types/amqplib": "^0",
    "@types/node": "^25.2.3",
    "@types/webpack": "^5.28.5",
    "@types/webpack-node-externals": "^3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "terser-webpack-plugin": "^5.3.16",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0"
  },
  "packageManager": "yarn@4.12.0"
}
