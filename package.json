{
  "name": "retail-inventory-system",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "nest build --all",
    "build:api-gateway": "nest build api-gateway",
    "build:inventory-microservice": "nest build inventory-microservice",
    "build:retail-microservice": "nest build retail-microservice",
    "build:notification-microservice": "nest build notification-microservice",
    "start:dev": "bash scripts/bash/start-dev.sh",
    "start:dev:api-gateway": "nest start api-gateway --watch",
    "start:dev:inventory-microservice": "nest start inventory-microservice --watch",
    "start:dev:retail-microservice": "nest start retail-microservice --watch",
    "start:dev:notification-microservice": "nest start notification-microservice --watch",
    "start:prod:api-gateway": "node dist/apps/api-gateway/main.js",
    "start:prod:inventory-microservice": "node dist/apps/inventory-microservice/main.js",
    "start:prod:retail-microservice": "node dist/apps/retail-microservice/main.js",
    "start:prod:notification-microservice": "node dist/apps/notification-microservice/main.js",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "format:check": "prettier --check \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "prepare": "husky",
    "typeorm:migration-cli": "ts-node --project tsconfig.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d ./migrations/config/data-source.ts",
    "migration:create": "ts-node ./scripts/migration-create.ts",
    "migration:run": "yarn typeorm:migration-cli migration:run",
    "migration:revert": "yarn typeorm:migration-cli migration:revert",
    "migration:show": "yarn typeorm:migration-cli migration:show",
    "test:seed": "ts-node -r tsconfig-paths/register scripts/test-db-seed.ts",
    "test:infra:up": "docker compose up mysql redis rabbitmq --wait",
    "test:infra:down": "docker compose down -v --remove-orphans",
    "test:infra:reload": "yarn test:infra:down && yarn test:infra:up && yarn migration:run && yarn test:seed",
    "test:unit": "jest --config jest.unit.config.js",
    "test:e2e:run": "jest --config jest.e2e.config.js --runInBand --forceExit",
    "test:e2e": "yarn test:infra:reload && yarn test:e2e:run"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/microservices": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "@scalar/nestjs-api-reference": "^1.1.5",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "express": "^5.2.1",
    "joi": "^18.1.1",
    "lodash": "^4.17.23",
    "mysql2": "^3.20.0",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28",
    "typeorm-naming-strategies": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.16",
    "@types/amqplib": "^0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@types/supertest": "^6.0.2",
    "@types/webpack": "^5.28.5",
    "@types/webpack-node-externals": "^3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "supertest": "^7.0.0",
    "terser-webpack-plugin": "^5.4.0",
    "ts-jest": "^29.3.4",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "webpack": "^5.105.4",
    "webpack-node-externals": "^3.0.0"
  },
  "packageManager": "yarn@4.12.0"
}
