{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@retail-inventory-system/common": ["libs/common"],
      "@retail-inventory-system/config": ["libs/config"],
      "@retail-inventory-system/inventory": ["libs/inventory"],
      "@retail-inventory-system/microservices": ["libs/microservices"],
      "@retail-inventory-system/retail": ["libs/retail"]
    }
  }
}
